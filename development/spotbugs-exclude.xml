<FindBugsFilter>
    <!-- Accepting mutable fields such as an injected RedisTemplate in component clasees -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="se.digg.wallet.gateway.infrastructure.auth.cache.ChallengeCache"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="se.digg.wallet.gateway.application.controller.AccountController"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="se.digg.wallet.gateway.domain.service.auth.AuthService"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="se.digg.wallet.gateway.domain.service.account.AccountService"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="se.digg.wallet.gateway.domain.service.wua.WuaService"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="se.digg.wallet.gateway.infrastructure.account.client.WalletAccountAdapter"/>
    </Match>

    <!-- Accept expose of internal representations and mutable fields in request and response model classes
    generated by the openapi-generator -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.gateway.api.v0.model.*"/>
    </Match>
    <Match>
        <Package name="~se\.digg\.wallet\.gateway\.client\.account\.v0.*"/>
    </Match>
    <Match>
        <Package name="~se\.digg\.wallet\.gateway\.client\.hsm\.v1.*"/>
    </Match>

    <!-- Accepting generated builders to have unusual namings -->
    <Match>
        <Bug pattern="NM_METHOD_NAMING_CONVENTION"/>
        <Class name="~.*Builder"/>
    </Match>

    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.gateway.domain.model.account.*"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.gateway.domain.model.hsm.*"/>
    </Match>
</FindBugsFilter>
